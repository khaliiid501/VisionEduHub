# Server config
PORT=8787
HOST=127.0.0.1

# Optional: restrict CORS to your frontend domain
ALLOWED_ORIGIN=http://localhost:8787

# Optional: enable AI-powered text refinement
OPENAI_API_KEY=sk-...

# Optional: override default AI model (default: gpt-4.1-mini)
OPENAI_ANALYZER_MODEL=gpt-4.1-mini

# Optional: PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/visioneduhub
